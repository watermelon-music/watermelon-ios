# Watermelon — config template. Copy to .env and fill in your values.
# .env is gitignored; this template is committed.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_KEY=your-supabase-anon-key
JAMENDO_CLIENT_ID=your-jamendo-client-id
PODCAST_INDEX_API_KEY=your-podcastindex-api-key
PODCAST_INDEX_SECRET=your-podcastindex-secret
WATERMELON_API_URL=https://watermelon-api-oxx2.onrender.com/

# Server-only — do NOT put a Supabase service_role key in the app.
